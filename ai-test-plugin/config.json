{
  "project_name": "登录注册 Demo 系统",
  "base_url": "http://127.0.0.1:5001",
  "request_timeout": 30,
  "llm": {
    "enabled": true,
    "provider": "openai",
    "model": "gpt-5.6"
  },
  "docs": {
    "prd": "../docs/PRD.md",
    "requirements": "../docs/requirements.md",
    "test_cases": "../docs/test_cases.md"
  },
  "generated": {
    "test_cases": "generated/test_cases.json",
    "generation_meta": "generated/generation_meta.json"
  },
  "api": {
    "register": "/api/register",
    "login": "/api/login",
    "userinfo": "/api/userinfo"
  },
  "outputs": {
    "test_results": "outputs/test_results.json",
    "test_report": "outputs/test_report.md",
    "bugs": "outputs/bugs.md"
  }
}
