[
  {
    "case_id": "TC-001",
    "module": "用户注册",
    "name": "用户名为空时注册失败",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "",
      "password": "{{valid_password}}"
    },
    "expected_status": 400,
    "expected_text": "用户名不能为空"
  },
  {
    "case_id": "TC-002",
    "module": "用户注册",
    "name": "用户名小于6位时注册失败",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "{{short_username}}",
      "password": "{{valid_password}}"
    },
    "expected_status": 400,
    "expected_text": "用户名长度不能少于6位"
  },
  {
    "case_id": "TC-003",
    "module": "用户注册",
    "name": "用户名等于6位时注册成功",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "{{six_char_username}}",
      "password": "{{valid_password}}"
    },
    "expected_status": 200,
    "expected_text": "注册成功"
  },
  {
    "case_id": "TC-004",
    "module": "用户注册",
    "name": "用户名超过20位时注册失败",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "abcdefghijklmnopqrstu",
      "password": "{{valid_password}}"
    },
    "expected_status": 400,
    "expected_text": "用户名长度不能超过20位"
  },
  {
    "case_id": "TC-005",
    "module": "用户注册",
    "name": "密码为空时注册失败",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "{{valid_username_a}}",
      "password": ""
    },
    "expected_status": 400,
    "expected_text": "密码不能为空"
  },
  {
    "case_id": "TC-006",
    "module": "用户注册",
    "name": "密码小于6位时注册失败",
    "method": "POST",
    "path": "/api/register",
    "payload": {
      "username": "{{valid_username_b}}",
      "password": "123"
    },
    "expected_status": 400,
    "expected_text": "密码长度不能少于6位"
  },
  {
    "case_id": "TC-007",
    "module": "用户注册",
    "name": "重复用户名注册失败",
    "method": "POST",
    "path": "/api/register",
    "setup": [
      {
        "method": "POST",
        "path": "/api/register",
        "payload": {
          "username": "{{duplicate_username}}",
          "password": "{{valid_password}}"
        }
      }
    ],
    "payload": {
      "username": "{{duplicate_username}}",
      "password": "{{valid_password}}"
    },
    "expected_status": 400,
    "expected_text": "该用户名已被注册"
  },
  {
    "case_id": "TC-008",
    "module": "用户登录",
    "name": "正确账号密码登录成功",
    "method": "POST",
    "path": "/api/login",
    "setup": [
      {
        "method": "POST",
        "path": "/api/register",
        "payload": {
          "username": "{{login_username}}",
          "password": "{{valid_password}}"
        }
      }
    ],
    "payload": {
      "username": "{{login_username}}",
      "password": "{{valid_password}}"
    },
    "expected_status": 200,
    "expected_text": "登录成功"
  },
  {
    "case_id": "TC-009",
    "module": "用户登录",
    "name": "密码错误时登录失败",
    "method": "POST",
    "path": "/api/login",
    "setup": [
      {
        "method": "POST",
        "path": "/api/register",
        "payload": {
          "username": "{{wrong_password_username}}",
          "password": "{{valid_password}}"
        }
      }
    ],
    "payload": {
      "username": "{{wrong_password_username}}",
      "password": "wrong-password"
    },
    "expected_status": 401,
    "expected_text": "用户名或密码错误"
  },
  {
    "case_id": "TC-010",
    "module": "用户登录",
    "name": "未注册用户登录失败",
    "method": "POST",
    "path": "/api/login",
    "payload": {
      "username": "{{unregistered_username}}",
      "password": "{{valid_password}}"
    },
    "expected_status": 401,
    "expected_text": "用户名或密码错误"
  },
  {
    "case_id": "TC-011",
    "module": "用户登录",
    "name": "登录用户名为空时失败",
    "method": "POST",
    "path": "/api/login",
    "payload": {
      "username": "",
      "password": "{{valid_password}}"
    },
    "expected_status": 400,
    "expected_text": "用户名不能为空"
  },
  {
    "case_id": "TC-012",
    "module": "用户登录",
    "name": "登录密码为空时失败",
    "method": "POST",
    "path": "/api/login",
    "payload": {
      "username": "{{valid_username_c}}",
      "password": ""
    },
    "expected_status": 400,
    "expected_text": "密码不能为空"
  }
]